                        <Font name="Arial" size="12.0" />
                     </font>
                     <VBox.margin>
                        <Insets top="7.0" />
                     </VBox.margin>
                  </Label>
                  <HBox alignment="CENTER_LEFT" prefWidth="200.0">
                     <children>
                        <CheckBox fx:id="checkboxShowPassword" mnemonicParsing="false" onAction="#onClickedShowPassword" styleClass="checkbox-showpassword" text="Show password" textFill="#57aeff">
                           <font>
                              <Font name="Poppins Regular" size="13.0" />
                           </font>
                        </CheckBox>
                        <HBox alignment="CENTER_RIGHT" prefWidth="200.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Hyperlink text="Forgot password" textFill="#56adff">
                                 <font>
                                    <Font name="Poppins Regular" size="14.0" />
                                 </font>
                              </Hyperlink>
                           </children>
                        </HBox>
                     </children>
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
            <Button mnemonicParsing="false" onAction="#onClickedLogin" prefWidth="300.0" styleClass="login-button" text="Log In" textFill="WHITE">
               <font>
                  <Font name="Poppins Bold" size="20.0" />
